# AI Scheduler Skill - 环境变量配置
# 复制此文件为 .env 并填入你的 API Keys

# ==================== 必需配置 ====================

# Moonshot API Key (Kimi AI)
# 获取地址: https://platform.moonshot.cn
MOONSHOT_API_KEY=your_moonshot_api_key_here

# Tavily API Key (搜索服务)
# 获取地址: https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ==================== 可选配置 ====================

# 高德地图 API Key (天气服务)
# 获取地址: https://lbs.amap.com
AMAP_WEBSERVICE_KEY=your_amap_key_here

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 端口配置
API_PORT=8000
NOTIFY_UI_PORT=8765
UI_PORT=3000

# ==================== 高级配置 ====================

# 调度器配置路径 (容器内路径)
# SCHEDULER_CONFIG=/app/config/scheduler.yaml

# 数据目录
# SCHEDULER_DATA_DIR=/app/data

# 日志目录
# SCHEDULER_LOG_DIR=/app/logs
