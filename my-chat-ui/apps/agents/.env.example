# Moonshot/Kimi API Key（用于定时任务调度器）
# 获取地址：https://platform.moonshot.cn/
MOONSHOT_API_KEY=your-moonshot-api-key

# 智谱 AI API Key（用于图像生成）
# 获取地址：https://open.bigmodel.cn/
ZHIPU_API_KEY=your-zhipu-api-key

# Tavily API Key（用于网络搜索）
# 获取地址：https://tavily.com/
TAVILY_API_KEY=your-tavily-api-key

# 高德地图 API Key（用于POI搜索、路线规划等功能）
# 获取地址：https://lbs.amap.com/api/webservice/create-project-and-key
AMAP_WEBSERVICE_KEY=your-amap-key

# 默认使用的AI模型
DEFAULT_MODEL=moonshot-v1-8k

# Scheduler Notification Webhook
AGENTS_WEBHOOK_URL=http://localhost:8890/api/notifications/webhook

# Feishu Bot Credentials
FEISHU_APP_ID=your_app_id
FEISHU_APP_SECRET=your_app_secret
FEISHU_RECEIVE_ID=your_receive_id
FEISHU_RECEIVE_ID_TYPE=open_id
