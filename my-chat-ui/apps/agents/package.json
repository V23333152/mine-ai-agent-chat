{
  "name": "agents",
  "author": "Your Name",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npx @langchain/langgraph-cli dev --port 2024 --config ../../langgraph.json",
    "api": "tsx src/api-server.ts",
    "build": "turbo build:internal --filter=agents",
    "build:internal": "pnpm run clean && tsc",
    "clean": "node -e \"require('fs').rmSync('./dist', {recursive: true, force: true}); require('fs').rmSync('./.turbo', {recursive: true, force: true});\" 2>nul || exit 0",
    "format": "prettier --config .prettierrc --write \"src\"",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.17.1",
    "@langchain/anthropic": "^0.3.15",
    "@langchain/cohere": "^0.3.2",
    "@langchain/community": "^0.3.59",
    "@langchain/core": "^0.3.80",
    "@langchain/langgraph": "^0.2.74",
    "@langchain/langgraph-checkpoint": "^0.0.18",
    "@langchain/mongodb": "^0.1.0",
    "@langchain/openai": "^0.4.4",
    "@langchain/pinecone": "^0.2.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@pinecone-database/pinecone": "^5.1.1",
    "dotenv": "^16.4.5",
    "langchain": "^0.3.19",
    "mongodb": "^6.14.2",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@eslint/js": "^9.22.0",
    "@jest/globals": "^29.7.0",
    "@langchain/langgraph-cli": "^0.0.19",
    "@types/node": "^20",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-no-instanceof": "^1.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^15.14.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "turbo": "latest",
    "typescript": "^5"
  }
}